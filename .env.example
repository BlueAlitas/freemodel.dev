# freemodel.dev status page — environment
#
# Copy to .env (or inject via Dokploy) and adjust as needed.

# Comma-separated list of Anthropic-compatible target URLs to probe.
TARGET_URLS=https://cc.freemodel.dev,https://api-cc.freemodel.dev

# Bearer token used for ALL target probes. Optional — leave blank to send
# no Authorization header (useful if your IP is whitelisted or you're
# testing locally).
FREEMODEL_TOKEN=

# Anthropic version header (some gateways check it).
ANTHROPIC_VERSION=2023-06-01

# Comma-separated list of model ids to test. By default we only enable
# haiku; uncomment to enable all discovered models.
# TEST_MODELS=claude-opus-4-8,claude-opus-4-7,claude-sonnet-4-6,claude-opus-4-6,claude-haiku-4-5-20251001
TEST_MODELS=claude-haiku-4-5-20251001

# Cadence
INTERVAL_HEALTHY_MS=1800000   # 30 min — used when last probe was 2xx
INTERVAL_RETRY_MS=60000       #  1 min — used until a 2xx is observed

# How often to re-poll /v1/models for new / retired models.
MODEL_REFRESH_MS=21600000     # 6 h

# Max history entries kept per (target, model) pair in status.json.
MAX_HISTORY=240

# Server
PORT=3000
DATA_PATH=./data/status.json
