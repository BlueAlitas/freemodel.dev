# freemodel.dev status page — environment
#
# Copy to .env (or inject via Dokploy) and adjust as needed.

# ─── Postgres ────────────────────────────────────────────────────
# Required. A postgres:// URL with full credentials.
DATABASE_URL=postgres://user:password@localhost:5432/freemodel_status

# Max Postgres connections opened by each Node process. In clustered mode,
# total app connections are roughly POSTGRES_POOL_MAX * (WEB_CONCURRENCY + 1).
POSTGRES_POOL_MAX=20

# ─── Targets to probe ───────────────────────────────────────────
# Comma-separated list of Anthropic-compatible target URLs.
TARGET_URLS=https://cc.freemodel.dev,https://api-cc.freemodel.dev

# Bearer token used for ALL target probes. Optional — leave blank to send
# no Authorization header (useful if your IP is whitelisted).
FREEMODEL_TOKEN=

# ─── Reverse proxy ───────────────────────────────────────────────
# Anthropic-compatible API proxy targets. T2 is preferred; T0 is fallback.
PROXY_T2_URL=https://api-cc.freemodel.dev
PROXY_T0_URL=https://cc.freemodel.dev

# Failed upstream responses are hidden from downstream callers until every
# configured credential/tier attempt is exhausted.
PROXY_RETRIES_PER_CREDENTIAL=10
PROXY_BODY_LIMIT=20mb

# Short cache for internal-account/key lookups on proxied requests. Set to 0
# to disable. Key changes can take this many milliseconds to affect traffic.
PROXY_ACCOUNT_CACHE_MS=5000
PROXY_ACCOUNT_CACHE_MAX=10000

# Required for /api/admin/* access. Send as x-admin-token, Authorization,
# or enter it on /admin.
ADMIN_TOKEN=

# Optional AES-GCM secret for stored upstream API keys. If omitted, keys are
# stored in a reversible local format so the proxy can still run.
PROXY_KEY_SECRET=

# Comma-separated list of model ids to test. By default we only enable
# haiku. Set to "*" to test every discovered model.
TEST_MODELS=claude-haiku-4-5-20251001

# Optional one-off probe controls for `node probe.js` / `node poller.js`.
# Defaults mirror the captured Claude Code title-generation request shape.
PROBE_TARGET_URL=https://api-cc.freemodel.dev
PROBE_SESSION_TEXT=Calculate 1+1
CLAUDE_CODE_BILLING_HEADER="cc_version=2.1.185.042; cc_entrypoint=cli;"

# ─── Cadence ─────────────────────────────────────────────────────
INTERVAL_HEALTHY_MS=1800000   # 30 min — used when last probe was 2xx
INTERVAL_RETRY_MS=60000       #  1 min — used until a 2xx is observed
# Keep retry cadence until this many consecutive probe requests are 2xx.
# Any failed probe resets this counter.
HEALTHY_CONFIRMATION_REQUESTS=50
MODEL_REFRESH_MS=21600000     #  6 h — re-poll /v1/models for new/retired models

# ─── Unique visitor tracking ─────────────────────────────────────
# Comma-separated path prefixes that should be tracked. /api/* is
# always excluded. Reloads update activity for the same IP + User-Agent
# fingerprint instead of creating another visit.
TRACK_PATHS=/

# Active-user window in minutes — used for the "active now" badge.
ACTIVE_WINDOW_MIN=5

# ─── Server ──────────────────────────────────────────────────────
PORT=3000

# Web worker processes sharing the same HTTP port. Use 1 for local debugging,
# 2-4 for a small Dokploy instance, or "auto" to match CPU count.
WEB_CONCURRENCY=2

# Keep true in production. Set false for cluster smoke checks that should not
# call upstream probe targets.
POLLER_ENABLED=true
